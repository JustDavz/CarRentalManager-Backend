            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": 6,\n  \"pickupBranchId\": 1,\n  \"startDate\": \"2026-07-01\",\n  \"endDate\": \"2026-07-05\"\n}",
